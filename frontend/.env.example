# Frontend Environment Variables
# For local development: copy to .env.local (auto-loaded by Vite, gitignored)
# For Render: set these in the Render dashboard → Environment

# API base URL
# Local:  leave blank (Vite proxy handles /api → localhost:8000)
# Render: set to your backend URL e.g. https://churchos-api.onrender.com/api/v1
VITE_API_BASE_URL=

# App name shown in browser tab (optional — fetched from backend settings)
VITE_APP_NAME=ChurchOS
