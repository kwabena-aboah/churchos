# ChurchOS — Render Environment Variables Reference
#
# These are set in the Render dashboard (NOT in this file for production).
# This file documents every variable the backend needs.
# For local dev, copy to .env and fill in values.

# ── Core Django ───────────────────────────────────────────────────────────────
DJANGO_ENV=render
SECRET_KEY=                         # Auto-generated by Render blueprint (generateValue: true)
DEBUG=False
ALLOWED_HOSTS=.onrender.com         # Render sets this; add your custom domain if you have one

# ── Database (auto-set by Render from the PostgreSQL add-on) ─────────────────
DATABASE_URL=                       # e.g. postgresql://user:pass@host/dbname?sslmode=require

# ── Redis (auto-set by Render from the Redis add-on) ─────────────────────────
REDIS_URL=                          # e.g. redis://red-xxxx:6379

# ── CORS (set to your frontend Render URL) ────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://churchos-frontend.onrender.com

# ── Time ──────────────────────────────────────────────────────────────────────
TIME_ZONE=Africa/Accra

# ── Email (SendGrid recommended) ──────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxx   # Your SendGrid API key
DEFAULT_FROM_EMAIL=noreply@yourchurch.org

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx               # For Whisper sermon transcription

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_SENDER_ID=+1234567890         # Or your alphanumeric sender ID

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_API_TOKEN=xxxx
WHATSAPP_PHONE_ID=xxxx

# ── Paystack (online donations) ───────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_SECRET_KEY=sk_live_xxxx

# ── AWS S3 (optional — for persistent media file storage) ─────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=churchos-media
# AWS_S3_REGION_NAME=us-east-1
